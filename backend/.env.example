# Minimax API — used for both tree indexing and RAG queries
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_GROUP_ID=your_minimax_group_id
MINIMAX_MODEL=MiniMax-M2.7

# LLM Provider for RAG pipeline — "minimax" | "anthropic" | "gemini" | "cerebras"
LLM_PROVIDER=cerebras

# Anthropic API (optional — routes through MiniMax proxy if using settings.json)
ANTHROPIC_API_KEY=sk-ant-your_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Gemini API (optional — uses Google AI Studio directly)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash-preview-05-20

# Cerebras API (optional — fast free tier: 1M tokens/day, ~2600 tok/sec)
CEREBRAS_API_KEY=your_cerebras_api_key
CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507

# Per-call timeout in seconds (default: 300)
LLM_TIMEOUT=300

# Paths (absolute or relative to backend/)
DATA_DIR=../data
BULLETIN_PDF=../data/bulletin.pdf
TREE_INDEX_PATH=../data/bulletin.tree.json
