# GCP / Vertex AI — required for vectorless RAG via Gemini
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_REGION=us-central1

# Gemini model for tree generation
PAGEINDEX_MODEL=gemini-3-flash-preview

# Paths (absolute or relative to backend/)
DATA_DIR=../data
BULLETIN_PDF=../data/bulletin.pdf
TREE_INDEX_PATH=../data/bulletin.tree.json
