f"""You are a WashU degree requirement assistant.
A student asks: "{query}"

Here is the document's table of contents with page ranges and summaries:

{tree_overview}

Your task:
1. Identify which section(s) of the table of contents are most relevant to answering this question.
2. Return the page ranges (start_index and end_index) for those sections as JSON.
3. Also return a brief answer to the question based on what you know about the document structure.

CRITICAL: You must respond with ONLY a valid JSON object. Do not include any text before or after the JSON. Do not write "Here is the JSON" or "Based on the document" or any explanation. Start directly with {{ and end directly with }}."""

    response = ChatGPT_API(model=model, prompt=prompt)
    # Strip MiniMax reasoning tags: replace start marker, keep end marker, split on it
    # Response: <think>thinking</think>{"answer":...}
    # After replace: <<<THINKING>>>thinking","answer":...}
    # Split on "</think>" to separate thinking from JSON
    parts = (response or "").replace("<think>", "<<<THINKING>>>", 1).split("</think>")
    post_think = parts[-1].strip() if len(parts) > 1 else (response or "")

    # Try standard JSON extraction first (handles responses that ARE JSON from the start)
    parsed = extract_json(post_think)
    sections = parsed.get("relevant_sections", []) or []
    answer = parsed.get("answer", "") if parsed else ""

    # ── Step 2: If we found relevant page ranges, READ the actual page content ──
    page_texts = []
    if sections:
        pdf_path = get_bulletin_pdf()
        if pdf_path.exists():
            try:
                from pageindex_agent.utils import get_text_of_pages
                for sec in sections[:3]:  # top 3 sections
                    start = sec.get("start_index", 0)
                    end = sec.get("end_index", start + 1)
                    # Expand range slightly to catch adjacent course table pages
                    text = get_text_of_pages(str(pdf_path), start, end + 2, tag=False)
                    # Fix character-spacing from PDF: "B I O L   3 2 4 0" -> "BIOL 3240"
                    # Collapse all single-char spaces between alphanumeric chars
                    text = re.sub(r'(?<=[A-Za-z0-9])\s(?=[A-Za-z0-9])', '', text)
                    # Put space before numbers in course codes: BIOL3240 -> BIOL 3240
                    text = re.sub(r'([A-Z]{2,})(\d)', r'\1 \2', text)
                    # Fix word boundaries: HumanGenetics -> Human Genetics
                    text = re.sub(r'([A-Z]+)([A-Z][a-z])', r'\1 \2', text)
                    # Collapse any multiple spaces
                    text = re.sub(r'\s{2,}', ' ', text)
                    page_texts.append(f"[Pages {start}-{end}]\n{text}")
            except Exception:
                pass

    if page_texts:
        # Build a proper answer using the actual page content (not just TOC summaries)
        conte